# ─── Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values

# Node
NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgres://iot_admin:iot_secret@localhost:5432/iot_platform

# Redis
REDIS_URL=redis://localhost:6379

# MQTT
MQTT_URL=mqtt://localhost:1883

# JWT — change these in production! Must be at least 32 characters
JWT_ACCESS_SECRET=change_me_super_secret_access_key_at_least_32ch
JWT_REFRESH_SECRET=change_me_super_secret_refresh_key_at_least_32c
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Cookie signing secret
COOKIE_SECRET=change_me_cookie_secret_key_in_production
